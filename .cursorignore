# mcp-guard .cursorignore

# ══════════════════════════════════════════════════════════════════════════════
# SECURITY - Never index secrets/credentials
# ══════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
.secrets
.secrets/
*.pem
*.key
*credentials*
*secret*

# ══════════════════════════════════════════════════════════════════════════════
# IDE/Personal (may contain paths/tokens)
# ══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
.cursor/
.claude/
.rake/

# ══════════════════════════════════════════════════════════════════════════════
# Dependencies
# ══════════════════════════════════════════════════════════════════════════════
node_modules/
**/node_modules/

# ══════════════════════════════════════════════════════════════════════════════
# Build outputs
# ══════════════════════════════════════════════════════════════════════════════
dist/
**/dist/
.next/
.turbo/

# ══════════════════════════════════════════════════════════════════════════════
# Lock files
# ══════════════════════════════════════════════════════════════════════════════
pnpm-lock.yaml
bun.lock
package-lock.json

# ══════════════════════════════════════════════════════════════════════════════
# Test/Coverage
# ══════════════════════════════════════════════════════════════════════════════
coverage/
*.log

# ══════════════════════════════════════════════════════════════════════════════
# External data (if accidentally present)
# ══════════════════════════════════════════════════════════════════════════════
data/
